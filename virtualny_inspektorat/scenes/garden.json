        "dialogue": {
          "nodes": [
            {
              "text": "The Arch's voice-activation system crackles to life:"
            },
            {
              "text": "P L E A S E   S T A T E   T H E   W O R D. You have four attempts before your existence is Q U E S T I O N E D.",
              "choices": [
                {
                  "text": "Malachite",
                  "correct": true,
                  "response": "W O R D   A C C E P T E D. The Arch unseals. Your pronunciation has been rated: A D E Q U A T E."
                },
                {
                  "text": "Obsidian",
                  "correct": false,
                  "response": "I N C O R R E C T. Obsidian is black. The Word is not black. This has been noted in your file."
                },
                {
                  "text": "Chrysalis",
                  "correct": false,
                  "response": "I N C O R R E C T. Chrysalis is golden. Golden is not the color of the Archive's heart."
                },
                {
                  "text": "Alabaster",
                  "correct": false,
                  "response": "I N C O R R E C T. Alabaster is white and forgettable. The Word is more... V I V I D."
                }
              ]
            }
          ]
        },
        "onSuccess": [
