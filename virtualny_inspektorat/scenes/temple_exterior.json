      "interactable": {
        "type": "dialogue",
        "hoverText": "☉ Speak to the Oracle",
        "dialogue": {
          "nodes": [
            {
              "speaker": "T H E   O R A C L E",
              "text": "W E L C O M E,   T R A V E L E R . . .",
              "next": 1
            },
            {
              "speaker": "T H E   O R A C L E",
              "text": "You stand at the threshold of the V I R T U A L N Y I N S P E K T O R A T. To enter, you must prove your mind is sharp enough to navigate its halls.",
              "next": 2
            },
            {
              "speaker": "T H E   O R A C L E",
              "text": "Answer me this: I have cities, but no houses. I have mountains, but no trees. I have water, but no fish. I have roads, but no cars. What am I?",
              "choices": [
                {
                  "text": "A map",
                  "correct": true,
                  "response": "Y E S . . .   You see beyond the surface. The temple opens its mouth to receive you. Enter, and discover what lies within the dream."
                },
                {
                  "text": "A painting",
                  "correct": false,
                  "response": "A painting has detail, but not the structure I describe. Think again, traveler..."
                },
                {
                  "text": "A computer",
                  "correct": false,
                  "response": "Technology is a mirror of the mind, but it is not what I am. Consider my words once more..."
                },
                {
                  "text": "A dream",
                  "correct": false,
                  "response": "Dreams are vast and formless. What I am is more... defined. Try again..."
                }
              ]
            }
          ]
        },
        "onSuccess": {
          "type": "transition",
          "target": "temple_interior"
        }
      }
    },
