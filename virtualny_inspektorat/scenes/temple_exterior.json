      "interactable": {
        "type": "dialogue",
        "hoverText": "☉ Speak to the Receptionist",
        "dialogue": {
          "nodes": [
            {
              "speaker": "R E C E P T I O N I S T",
              "text": "T A K E   A   N U M B E R . . .   Your number is: I N F I N I T Y.  Please wait until your number is called.",
              "next": 1
            },
            {
              "speaker": "R E C E P T I O N I S T",
              "text": "...Actually, you appear to have an A P P O I N T M E N T. Seven years overdue. This is... acceptable.",
              "next": 2
            },
            {
              "speaker": "R E C E P T I O N I S T",
              "text": "Before you may enter, you must answer the mandatory S E C U R I T Y   Q U E S T I O N. State the purpose of your visit.",
              "choices": [
                {
                  "text": "To obtain my certificate",
                  "correct": true,
                  "response": "The Z A S V I E D C Z E N I E. Your request has been... L O G G E D. Proceed to the Hall of Forms. Take nothing that is not yours. Take everything that is required."
                },
                {
                  "text": "To seek the truth",
                  "correct": false,
                  "response": "Truth is not a service we provide. Try the Department of Philosophy. It closed seven centuries ago."
                },
                {
                  "text": "To gain power",
                  "correct": false,
                  "response": "Power is reserved for management. Please state your actual purpose."
                },
                {
                  "text": "I don't remember",
                  "correct": false,
                  "response": "You remember. You have always remembered. Please consult your original summons."
                }
              ]
            }
          ]
        },
        "onSuccess": {
          "type": "transition",
          "target": "temple_interior"
        }
      }
