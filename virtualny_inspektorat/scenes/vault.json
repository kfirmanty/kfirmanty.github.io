      "interactable": {
        "type": "dialogue",
        "hoverText": "☉ Speak to the Auditor",
        "requires": "vault_open",
        "requiresText": "The Auditor looms beyond the security barrier. Its eyes scan endlessly, verifying, verifying...",
        "dialogue": {
          "nodes": [
            {
              "speaker": "T H E   A U D I T O R",
              "text": "Your documents have been R E V I E W E D. There is... an inconsistency."
            },
            {
              "speaker": "T H E   A U D I T O R",
              "text": "Your records contradict themselves. This is U N U S U A L. Usually they contradict someone else's."
            },
            {
              "speaker": "T H E   A U D I T O R",
              "text": "You must reconcile this discrepancy. Which statement is C O R R E C T?",
              "choices": [
                {
                  "text": "All of the above",
                  "correct": true,
                  "response": "C O R R E C T. Per Regulation §47.3(b), all contradictory records are simultaneously valid. This has always been true. You have always known this. You may P R O C E E D to the Director."
                },
                {
                  "text": "I exist (Tablet A)",
                  "correct": false,
                  "response": "But Tablet B says otherwise. And its record is also F I N A L. You cannot choose one truth in a system that runs on many."
                },
                {
                  "text": "I don't exist (Tablet B)",
                  "correct": false,
                  "response": "If you do not exist, then who is standing before me? And who was standing here before you?"
                },
                {
                  "text": "It doesn't matter (Tablet C)",
                  "correct": false,
                  "response": "It is administrative, yes. But administrative matters are the O N L Y matters in the Inspektorat. Try again."
                }
              ]
            }
          ]
        },
        "onSuccess": {
          "type": "transition",
          "target": "appeals"
        }
      }
